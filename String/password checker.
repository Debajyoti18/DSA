//.Minimum char add to make Valid password of 6 character



public static int minimumNumber(int n, String password) {
    // Return the minimum number of characters to make the password strong
     boolean[] found = new boolean[4];//4types of chars in password ,digit,lowerchar,upperchar,special
        String st = "!@#$%^&*()-+";
        int add =0;
       for(char c : password.toCharArray()){
        if(Character.isDigit(c))found[0]=true;
        else if (Character.isLowerCase(c)) found[1]=true;
        else if(Character.isUpperCase(c))found[2]=true;
        else if(st.indexOf(c) != -1) found[3]=true;
       }
       for(boolean t : found){
        if(!t){
            add++;
        }
       }
       return Math.max(add,Math.max(0,6-n));
    }
