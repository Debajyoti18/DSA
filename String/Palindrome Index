 public static int palindromeIndex(String s) {
            StringBuffer sb = new StringBuffer(s);
            if(s.equals(sb.reverse().toString())){
                return -1;
            }
            int n = s.length()-1,i = 0;
            while(i<n && s.charAt(i)==s.charAt(n)){
                i++;
                n--;
            }
           if(isPalindrome(s,i+1,n)){ //eg for baaa ,check for aaa is palindrome or not .yes so return b index
            return i;
           }
           
            if(isPalindrome(s,i,n-1)){//eg for aaab ,check for aaa is palindrome .so return b index 
                return n;
            }
            return -1;//already palindrome
            
    }
    public static boolean isPalindrome(String s,int l,int r){
        while(l<r){
            if(s.charAt(l)!=s.charAt(r)){
                return false;
            }
            l++;
            r--;
        }
        return true;
    }
